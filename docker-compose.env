# --- SYSTEEM & UI ---
TZ=Europe/Amsterdam
UVICORN_RELOAD=0
TRANSFORMERS_VERBOSITY=error
HF_HUB_DISABLE_PROGRESS_BARS=1
TOKENIZERS_PARALLELISM=false
PORTAL_SNAPSHOT_INTERVAL_SEC=1.5
SYSTEM_STATS_DISK_PATH=/hostfs

# --- MARKT SCANNER ---
DEFAULT_TICKER=BTC-EUR
TICKERS=BTC-EUR,ETH-EUR,XRP-EUR,SOL-EUR
SCANNER_TOP_VOLUME=30
SCANNER_TOP_VOLUME_POOL=50
SCANNER_ELITE_COUNT=8
SCANNER_MOVER_MIN_VOLUME_EUR=1000000
SCANNER_MIN_MARKET_CAP_EUR=500000000
SCANNER_INTERVAL_SEC=3600
LOOKBACK_DAYS=400
MIN_24H_VOLUME_EUR=500000
SOCIAL_REFRESH_SEC=300
SOCIAL_HIGH_INTEREST_PCT=300

# --- RISK MANAGEMENT ---
PAPER_START_BALANCE_EUR=10000
RISK_SIZING_MODE=fixed_eur
RISK_BASE_TRADE_EUR=100
RISK_MAX_TRADE_EQUITY_PCT=10
RISK_MAX_PER_ASSET_TRADE_PCT=20
RISK_MAX_POSITION_EQUITY_PCT=40
RISK_STOP_LOSS_PCT=2.5
RISK_TAKE_PROFIT_PCT=5.0
PAIR_MIN_QUOTE_BALANCE=50
PAIR_MIN_BASE_BALANCE=0.00001

# --- AI & RL ENGINE ---
ENGINE_LOOP_MINUTES=1
RL_EPISODE_HOURS=24
RL_EPISODE_TRAIN_STEPS=3000
FINBERT_USE_CUDA=1
RL_SEED_FIRST_POSITION=1
RL_SEED_NOTIONAL_EUR=500
RL_ACTION_MIN_CONFIDENCE=0.75
RL_BACKGROUND_TRAIN=1
RL_PPO_DEVICE=cpu
RL_BG_TRAIN_CONCURRENCY=1
RL_TRAIN_CHUNK_STEPS=1000
RL_PRIORITY_PAIR_TRAIN_MULT=1.65
RL_TRAIN_INTERVAL_SEC=120
RL_MULTI_INFER_INTERVAL_SEC=60
RL_CHECKPOINT_INTERVAL_SEC=3600

# --- STORAGE & INFRA ---
REDIS_URL=redis://redis:6379/0
RL_METRICS_DB_PATH=/app/logs/rl_training_metrics.sqlite
TRADE_HISTORY_DB_PATH=/app/storage/trade_history.db
PAPER_BITVAVO_DB_PATH=/app/storage/paper_bitvavo.db
AI_TRADING_STORAGE_ROOT=/app/storage
RL_TRAINING_CHART_MAX_POINTS=12000
RL_DATA_AUDIT_HEARTBEAT=0
GENESIS_HEAL_ALLOW_CPU_LOG=0

