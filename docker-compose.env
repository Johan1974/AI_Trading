# --- PROJECT ROOT & VAULT (host-side referenties) ---
# Gebruik deze variabelen in scripts en documentatie als je het volledige pad nodig hebt.
# In containers zijn dit host-paden — gebruik /app/... voor container-interne paden.
# PROJECT_DIR en VAULT_PATH zijn host-specifiek; stel in via ~/.trading_vault of pas hieronder aan.
# PROJECT_DIR=$(pwd)   # automatisch via run_all.sh
# VAULT_PATH=~/.trading_vault

# --- SYSTEEM & UI ---
TZ=Europe/Amsterdam
UVICORN_RELOAD=0
# Portal: meerdere workers vermindert ERR_EMPTY_RESPONSE als /predictions + /stats tegelijk sync werk doen
UVICORN_WORKERS=2
TRANSFORMERS_VERBOSITY=error
HF_HUB_DISABLE_PROGRESS_BARS=1
TOKENIZERS_PARALLELISM=false
PORTAL_SNAPSHOT_INTERVAL_SEC=1.5
SYSTEM_STATS_DISK_PATH=/hostfs
# GPU: één achtergrond-thread pollt nvidia-smi iedere N sec (default 60). Legacy: SYSTEM_STATS_GPU_MIN_INTERVAL_SEC als POLL niet gezet.
SYSTEM_STATS_GPU_POLL_INTERVAL_SEC=60
SYSTEM_STATS_GPU_MIN_INTERVAL_SEC=60

# --- MARKT SCANNER ---
# Top 20 Bitvavo EUR-paren op 24h volume (volumeQuote). Zet op 0 voor standaard (dynamic scanner + TICKERS-filter).
BITVAVO_ACTIVE_TOP_N=20
# Uitgesloten base-tickers (nooit in active_markets / volume-rank), ook als ze hoog volume krijgen.
BITVAVO_EXCLUDE_BASES=JUP,ICP,HBAR,USDC
# UI/ledger: alle 20 markten; RL werkt alleen op de kop (zelfde sort = hoogste EUR-volume eerst).
RL_MULTI_INFER_MAX_PAIRS=6
RL_MULTI_INFER_CONCURRENCY=1
RL_BG_TRAIN_MAX_MARKETS=6
DEFAULT_TICKER=BTC-EUR
TICKERS=BTC-EUR,ETH-EUR,XRP-EUR,SOL-EUR,SUI-EUR,ADA-EUR
SCANNER_TOP_VOLUME=30
SCANNER_TOP_VOLUME_POOL=50
SCANNER_ELITE_COUNT=8
SCANNER_MOVER_MIN_VOLUME_EUR=1000000
SCANNER_MIN_MARKET_CAP_EUR=500000000
SCANNER_INTERVAL_SEC=3600
LOOKBACK_DAYS=400
MIN_24H_VOLUME_EUR=500000
SOCIAL_REFRESH_SEC=300
SOCIAL_HIGH_INTEREST_PCT=300

# --- RISK MANAGEMENT ---
PAPER_START_BALANCE_EUR=1000
PAPER_RESET_BALANCE_EUR=1000
RISK_SIZING_MODE=fixed_eur
RISK_BASE_TRADE_EUR=100
RISK_MAX_TRADE_EQUITY_PCT=10
RISK_MAX_PER_ASSET_TRADE_PCT=20
RISK_MAX_POSITION_EQUITY_PCT=40
RISK_STOP_LOSS_PCT=2.5
RISK_TAKE_PROFIT_PCT=5.0
# Paper: daily stop vs startkapitaal (open inleg telt mee in equity); 15% voorkomt false alarm bij ~10%-posities.
DAILY_STOP_LOSS_PCT=15
# Na herstel boven de drempel: bot_status weer running (paper); zet op 0 om handmatige pause te respecteren tot /bot/resume.
PAPER_DAILY_STOP_AUTO_RESUME=1
# 1 = paper sync-cycle voert geen orders uit (``_run_paper_cycle_sync``). Bij incident tijdelijk op 1.
PAPER_EXECUTION_PAUSE=0
# 1 = max. één open paper-positie per coin (Bitvavo: alleen *-EUR paren; voorkomt dubbele ETH-EUR / dubbele basis in wallet).
PAPER_ENFORCE_ONE_OPEN_TRADE_PER_BASE=1
# Paper execution: vloer spread vóór mid→fill (bps); 10 = 0.10%.
PAPER_MIN_SPREAD_BPS=10
# Deep Learning Night Run (P2): 1 = fills gebruiken halve spread + slippage t.o.v. mid (orderbook-geschat).
PAPER_FORCE_ORDERBOOK_EXECUTION_PRICE=1
# BUY: halve size_frac bij RL-confidence in (0.50, 0.60]; vol boven 0.60. Zet op 1 om te activeren.
PAPER_CONFIDENCE_POSITION_SCALE=0

# --- IRON LOCKDOWN (strikte allocatie + globale BUY-flock in worker_execution) ---
IRON_LOCKDOWN=1
IRON_STRICT_ALLOCATION=1
IRON_MAX_TRADE_EUR=100
IRON_MAX_OPEN_COINS=8
IRON_MAX_TOTAL_EXPOSURE_EUR=800
PAPER_BUY_IRON_FLOCK=1
PAIR_MIN_QUOTE_BALANCE=50
PAIR_MIN_BASE_BALANCE=0.00001

# --- AI & RL ENGINE ---
# Lichte obs-jitter per paar op infer (worker): voorkomt identieke PPO-softmax als account+nieuws-rij gelijk ogen.
RL_INFER_PAIR_JITTER=0.0008
ENGINE_LOOP_MINUTES=1
RL_EPISODE_HOURS=24
RL_EPISODE_TRAIN_STEPS=3000
FINBERT_USE_CUDA=1
RL_SEED_FIRST_POSITION=1
RL_SEED_NOTIONAL_EUR=500
# News signal boost (tijdelijk voor test): verhoogt news-features in observatie voor attention-gate.
RL_NEWS_SIGNAL_BOOST=3.0
# Minimum news feature floor per feature (individueel, vóór hernomarisatie).
RL_NEWS_FEATURE_FLOOR=0.08
# Minimum SOM van news-gewichten in Brain Lab weergave (0.20 = 20%).
RL_NEWS_WEIGHT_MIN=0.20
# Lagere drempel → vaker instappen (sync met STATE decision_threshold na paper-reset)
EXPECTED_RETURN_SIGNAL_THRESHOLD_PCT=0.20
RL_REWARD_DD_THRESHOLD=0.04
RL_REWARD_DD_EXP_K=3.0
RL_REWARD_DD_EXP_SCALE=1.0
RL_ACTION_MIN_CONFIDENCE=0.20
# Forceer eerste exploratietrade na stagnatie (0=uit, 1=aan)
RL_EXPLORATION_FORCE_TRADE_ENABLED=1
RL_EXPLORATION_FORCE_TRADE_STALL_HOURS=2
RL_EXPLORATION_FORCE_TRADE_SIZE_PCT=5
RL_EXPLORATION_INFERENCE_EPS=0.40
RL_EXPLORATION_FINAL_EPS=0.40
# Ondergrens ε (paper): tijdelijk verhoogd om vliegwiel te starten.
RL_EXPLORATION_MIN_EPS=0.15
# Zet op 1 om AUTO-OPT weer ε te laten tweaken op basis van 24h PF/WR.
AUTO_OPT_TUNE_EPSILON=0
RL_MICRO_UPDATE_STEPS_ON_CLOSE=1024
RL_MIN_EXPERIENCES_FOR_MICRO_TRAIN=1
WATCHDOG_STALL_LIMIT_SEC=1200
RL_BACKGROUND_TRAIN=1
RL_PPO_DEVICE=cpu
RL_BG_TRAIN_CONCURRENCY=1
RL_TRAIN_CHUNK_STEPS=1000
RL_PRIORITY_PAIR_TRAIN_MULT=1.65
RL_TRAIN_INTERVAL_SEC=120
RL_MULTI_INFER_INTERVAL_SEC=60
RL_CHECKPOINT_INTERVAL_SEC=3600

# --- STORAGE & INFRA ---
REDIS_URL=redis://redis:6379/0
RL_METRICS_DB_PATH=/app/storage/rl_training_metrics.sqlite
TRADE_HISTORY_DB_PATH=/app/data/database.db
PAPER_BITVAVO_DB_PATH=/app/storage/paper_bitvavo.db
AI_TRADING_STORAGE_ROOT=/app/storage
RL_TRAINING_CHART_MAX_POINTS=12000
RL_DATA_AUDIT_HEARTBEAT=0
GENESIS_HEAL_ALLOW_CPU_LOG=0

# --- Deep Learning Night Run (Helsinki): RL snapshot logging + auto-calibration ---
# Worker ``generate_prediction`` (/predict): volledige featurevector → SQLite ``predict_rl_feature_snapshots``.
RL_PREDICT_FEATURE_LOG=1
RL_PREDICT_SNAPSHOT_MAX_CHARS=1800000
AUTO_CALIBRATION_ENABLED=0
AUTO_CALIBRATION_INTERVAL_SEC=86400
# Extra decision_threshold (+delta) wanneer gemiddelde 24h Elite win-rate onder deze % duikt.
AUTO_CALIBRATION_WIN_RATE_LOW_PCT=45
AUTO_CALIBRATION_LOW_WIN_EXTRA_THRESHOLD_DELTA=0.05

# Equity-integriteitscheck: 0 = log en ga door (geen sys.exit bij mismatch)
PORTFOLIO_MATH_FATAL_EXIT=0


# --- NEWS CONTAINER ---
NEWS_SENTIMENT_TTL_SEC=900
NEWS_FETCH_INTERVAL_SEC=300
NEWS_SENTIMENT_DB_PATH=data/news_sentiment.db
